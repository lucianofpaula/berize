datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USUÁRIO GLOBAL E CONTROLE DE ACESSO
// ==========================================

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  whatsapp      String?
  password      String? // Hash da senha (para login tradicional)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relações de Autenticação
  accounts Account[]
  sessions Session[]

  // Relação com as empresas (Tenants) que ele participa
  tenantMembers     TenantMember[]
  referredCompanies Company[]      @relation("CompanyReferrer")
  // Empresas que este usuário é dono (reivindicadas)
  ownedCompanies    Company[]      @relation("CompanyOwner")

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==========================================
// 2. ESTRUTURA DE TENANTS (EMPRESAS)
// ==========================================

model Company {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String        @unique // Ex: "barbeariadocanhoto"
  status    CompanyStatus @default(CLAIMABLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  logo          String? // URL da logo da empresa
  // --- CAMPOS DE INDICAÇÃO E PROPRIEDADE ---

  // ID do usuário que indicou esta empresa (opcional)
  referredById String? @db.ObjectId
  // ID do usuário que é o dono real e reivindicou a empresa (opcional)
  ownerId      String? @db.ObjectId

  // Relações com o Prisma (mapeando os caminhos acima)
  referredBy User?          @relation("CompanyReferrer", fields: [referredById], references: [id], onDelete: SetNull)
  owner      User?          @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // Relação com os membros/clientes desta empresa
  members    TenantMember[]
  // Planos e serviços da empresa
  plans      Plan[]
  services   Service[]

  @@map("companies")
}

// ==========================================
// 3. O PULO DO GATO: RELAÇÃO MULTI-TENANT E MMN
// ==========================================

model TenantMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Vínculos obrigatórios
  userId    String @db.ObjectId
  companyId String @db.ObjectId

  // Papel do usuário dentro da empresa
  role TenantRole @default(CLIENT)

  // Dados financeiros e de fidelidade específicos desta empresa
  loyaltyPoints     Int   @default(0)
  commissionBalance Float @default(0.0)

  // Perfil de barbeiro (apenas se role = BARBER)
  barberProfile BarberProfile?

  // --- ESTRUTURA DO MARKETING MULTINÍVEL (MMN) ---

  // ID do patrocinador direto (é outro TenantMember desta mesma empresa)
  sponsorId String? @db.ObjectId

  // Caminho materializado: Array com os IDs de todos os ancestrais na rede desta empresa
  // No Prisma com MongoDB, definimos arrays de String representados por ObjectIds assim:
  ancestors String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações mapeadas no Prisma
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relação interna para achar o patrocinador direto dentro da mesma coleção
  sponsor   TenantMember?  @relation("Sponsorship", fields: [sponsorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sponsored TenantMember[] @relation("Sponsorship")

  // Evita que o mesmo usuário se vincule mais de uma vez à mesma empresa
  @@unique([userId, companyId])
  // Índice para buscas rápidas de árvore por empresa
  @@index([companyId, ancestors])
  @@map("tenant_members")
}

// ==========================================
// 4. PERFIL DE BARBEIRO
// ==========================================

model BarberProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantMemberId String   @unique @db.ObjectId
  specialty      String[] // Especialidades (ex: ["Corte masculino", "Barba"])
  commissionRate Float    @default(0.0) // Percentual de comissão (0.0 a 100.0)
  photoUrl       String?  // URL da foto no Cloudinary
  bio            String?  // Biografia / descrição do barbeiro
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenantMember TenantMember @relation(fields: [tenantMemberId], references: [id], onDelete: Cascade)
  availability BarberAvailability[]

  @@map("barber_profiles")
}

// ==========================================
// 5. DISPONIBILIDADE SEMANAL DO BARBEIRO
// ==========================================

model BarberAvailability {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  barberProfileId String   @db.ObjectId
  dayOfWeek       Int      // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  startTime       String   // "08:00"
  endTime         String   // "18:00"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barberProfile BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)

  @@map("barber_availability")
}

// ==========================================
// 6. PLANOS DE ASSINATURA
// ==========================================

model Plan {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String        @db.ObjectId
  name            String
  description     String?
  price           Float
  badge           String?       // Ex: "Recomendado", "Mais popular", "Premium"
  includedServiceIds String[] @db.ObjectId // IDs dos serviços incluídos neste plano
  commissionTiers Json          // [{"level":1,"percentage":20},{"level":2,"percentage":10}]
  status          PlanStatus    @default(ACTIVE)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("plans")
}

// ==========================================
// 7. SERVIÇOS
// ==========================================

model Service {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String      @db.ObjectId
  name            String
  description     String?
  price           Float
  duration        Int         // Duração em minutos
  category        String?     // Ex: "Corte", "Barba", "Hidratação"
  commissionTiers Json        // [{"level":1,"percentage":20}]
  status          ServiceStatus @default(ACTIVE)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("services")
}

// ==========================================
// ENUNS
// ==========================================
enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}
enum TenantRole {
  OWNER
  BARBER
  CLIENT
}
enum CompanyStatus {
  ACTIVE // Empresa ativa, mensalidade em dia, site funcionando
  BLOCKED // Bloqueada por falta de pagamento (exibe tela de aviso)
  INACTIVE // Desativada pelo próprio dono
  CLAIMABLE // Cadastrada por um usuário comum, aguardando o dono real reivindicar
}
