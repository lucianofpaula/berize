datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USUÁRIO GLOBAL E CONTROLE DE ACESSO
// ==========================================

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  whatsapp      String?
  password      String? // Hash da senha (para login tradicional)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relações de Autenticação
  accounts Account[]
  sessions Session[]

  // Relação com as empresas (Tenants) que ele participa
  tenantMembers     TenantMember[]
  referredCompanies Company[]      @relation("CompanyReferrer")
  // Empresas que este usuário é dono (reivindicadas)
  ownedCompanies    Company[]      @relation("CompanyOwner")
  // Categorias criadas por este usuário
  createdBusinessCategories  BusinessCategory[]      @relation("BusinessCategoriesCreated")
  createdProfessionalCategories ProfessionalCategory[] @relation("ProfessionalCategoriesCreated")

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==========================================
// 2. ESTRUTURA DE TENANTS (EMPRESAS)
// ==========================================

model Company {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  slug      String        @unique // Ex: "barbeariadocanhoto"
  status    CompanyStatus @default(CLAIMABLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  logo          String? // URL da logo da empresa

  // --- INFORMAÇÕES GERAIS ---
  description String? // Descrição do negócio
  phone       String? // Telefone fixo
  whatsapp    String? // WhatsApp
  email       String? // E-mail de contato

  // --- ENDEREÇO (JSON) ---
  // { "street": "...", "number": "...", "complement": "...", "neighborhood": "...", "city": "...", "state": "...", "zipCode": "..." }
  address Json?

  // --- REDES SOCIAIS (JSON) ---
  // { "instagram": "...", "facebook": "...", "tiktok": "...", "youtube": "..." }
  socialMedia Json?

  // --- DOMÍNIO PERSONALIZADO ---
  customDomain   String?  // Ex: "barbearia.meudominio.com.br"
  domainVerified Boolean  @default(false)

  // --- CONFIGURAÇÕES DE AGENDAMENTO ---
  timezone            String @default("America/Sao_Paulo")
  appointmentLeadTime Int    @default(60) // Minutos mínimos de antecedência
  appointmentInterval Int    @default(30) // Intervalo entre horários (minutos)

  // --- METAS ---
  dailyAppointmentGoal Int    @default(0) // Meta de agendamentos por dia
  dailyRevenueGoal     Float  @default(0) // Meta de faturamento diário (R$)

  // --- CAMPOS DE INDICAÇÃO E PROPRIEDADE ---

  // ID do usuário que indicou esta empresa (opcional)
  referredById String? @db.ObjectId
  // ID do usuário que é o dono real e reivindicou a empresa (opcional)
  ownerId      String? @db.ObjectId

  // Relações com o Prisma (mapeando os caminhos acima)
  referredBy User?          @relation("CompanyReferrer", fields: [referredById], references: [id], onDelete: SetNull)
  owner      User?          @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // Relação com os membros/clientes desta empresa
  members    TenantMember[]
  // Planos e serviços da empresa
  plans      Plan[]
  services   Service[]
  // Agendamentos
  appointments Agendamento[]
  // Horários de funcionamento
  hours     CompanyHours[]
  // Categoria do estabelecimento
  businessCategoryId String? @db.ObjectId
  businessCategory   BusinessCategory? @relation(fields: [businessCategoryId], references: [id], onDelete: SetNull)

  // Campanhas de marketing
  campaigns Campaign[]

  @@map("companies")
}

// ==========================================
// 9. HORÁRIOS DE FUNCIONAMENTO DA EMPRESA
// ==========================================

model CompanyHours {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  dayOfWeek Int      // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  openTime  String   // "08:00"
  closeTime String   // "18:00"
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, dayOfWeek])
  @@map("company_hours")
}

// ==========================================
// 9. CAMPANHAS DE MARKETING
// ==========================================

model Campaign {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String   @db.ObjectId
  title           String
  subtitle        String?
  description     String?
  highlightTitle  String?  // Título em destaque (chamativo)
  badge           String?  // Tag: "Novidade", "Tempo Limitado", "Exclusivo"
  buttonText      String   @default("Saiba Mais")
  buttonUrl       String?  // URL opcional para onde o botão leva

  // Typography
  titleColor      String   @default("#FFFFFF")
  titleSize       String   @default("text-3xl") // text-2xl | text-3xl | text-4xl | text-5xl
  buttonColor     String   @default("#F97316")
  buttonTextColor String   @default("#FFFFFF")
  textAlign       String   @default("left") // left | center | right

  // Card style preset
  cardStyle       String   @default("premium") // classic | gradient | premium | minimal | bordered | highlight

  // Custom background
  cardBackground  String?  // Cor sólida de fundo (hex) — sobrepõe o padrão do estilo
  gradientStart   String?  // Cor inicial do gradiente (ex: #F97316)
  gradientEnd     String?  // Cor final do gradiente (ex: #EA580C)
  gradientDirection String @default("to-br") // to-r | to-br | to-b | to-bl | to-l | to-tl

  // Border customizations
  borderEnabled   Boolean  @default(true)
  borderColor     String?  // Cor da borda (hex) — sobrepõe a cor padrão
  borderWidth     String   @default("border") // border | border-2 | border-4

  // Animation
  animation       String   @default("none") // none | pulse | glow | shimmer | float

  // Resgate
  redemptionType  String   @default("unique") // unique | recurring
  requiresCoupon  Boolean  @default(false)
  couponPrefix    String?  // Prefixo do cupom: ex "CORTE24"

  // Duração
  startDate       DateTime
  endDate         DateTime

  // Controle
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  coupons Coupon[]

  @@index([companyId, isActive])
  @@map("campaigns")
}

model Coupon {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  campaignId String       @db.ObjectId
  code       String       @unique // Código único do cupom (ex: CORTE24-A7X3K)
  clientName String?      // Nome do cliente que retirou
  clientPhone String?     // WhatsApp/telefone do cliente
  status     CouponStatus @default(ACTIVE) // ACTIVE | USED | EXPIRED | CANCELLED
  usedAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("coupons")
}

// ==========================================
// 10. CATEGORIAS
// ==========================================

model BusinessCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  icon        String?  // Nome do ícone (lucide) para representação visual
  color       String?  // Hex color ex: "#f97316"
  slug        String   @unique
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String   @db.ObjectId // ID do usuário que criou
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User      @relation("BusinessCategoriesCreated", fields: [createdById], references: [id])
  companies   Company[]

  @@map("business_categories")
}

model ProfessionalCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  icon        String?  // Nome do ícone (lucide) para representação visual
  color       String?  // Hex color ex: "#3b82f6"
  slug        String   @unique
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdById String   @db.ObjectId // ID do usuário que criou
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User              @relation("ProfessionalCategoriesCreated", fields: [createdById], references: [id])
  barberProfiles BarberProfile[]

  @@map("professional_categories")
}

// ==========================================
// 3. O PULO DO GATO: RELAÇÃO MULTI-TENANT E MMN
// ==========================================

model TenantMember {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Vínculos obrigatórios
  userId    String @db.ObjectId
  companyId String @db.ObjectId

  // Papel do usuário dentro da empresa
  role TenantRole @default(CLIENT)

  // Dados financeiros e de fidelidade específicos desta empresa
  loyaltyPoints     Int   @default(0)
  commissionBalance Float @default(0.0)

  // Perfil de barbeiro (apenas se role = BARBER)
  barberProfile BarberProfile?

  // --- ESTRUTURA DO MARKETING MULTINÍVEL (MMN) ---

  // ID do patrocinador direto (é outro TenantMember desta mesma empresa)
  sponsorId String? @db.ObjectId

  // Caminho materializado: Array com os IDs de todos os ancestrais na rede desta empresa
  // No Prisma com MongoDB, definimos arrays de String representados por ObjectIds assim:
  ancestors String[] @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações mapeadas no Prisma
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relação interna para achar o patrocinador direto dentro da mesma coleção
  sponsor   TenantMember?  @relation("Sponsorship", fields: [sponsorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sponsored TenantMember[] @relation("Sponsorship")

  // Agendamentos
  barberAppointments  Agendamento[] @relation("BarberAppointments")
  clientAppointments  Agendamento[] @relation("ClientAppointments")

  // Evita que o mesmo usuário se vincule mais de uma vez à mesma empresa
  @@unique([userId, companyId])
  // Índice para buscas rápidas de árvore por empresa
  @@index([companyId, ancestors])
  @@map("tenant_members")
}

// ==========================================
// 4. PERFIL DE BARBEIRO
// ==========================================

model BarberProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantMemberId String   @unique @db.ObjectId
  specialty      String[] // Especialidades (ex: ["Corte masculino", "Barba"])
  commissionRate Float    @default(0.0) // Percentual de comissão (0.0 a 100.0)
  photoUrl       String?  // URL da foto no Cloudinary
  bio            String?  // Biografia / descrição do barbeiro
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenantMember           TenantMember          @relation(fields: [tenantMemberId], references: [id], onDelete: Cascade)
  availability           BarberAvailability[]
  professionalCategoryId String?               @db.ObjectId
  professionalCategory   ProfessionalCategory?  @relation(fields: [professionalCategoryId], references: [id], onDelete: SetNull)

  @@map("barber_profiles")
}

// ==========================================
// 5. DISPONIBILIDADE SEMANAL DO BARBEIRO
// ==========================================

model BarberAvailability {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  barberProfileId String   @db.ObjectId
  dayOfWeek       Int      // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
  startTime       String   // "08:00"
  endTime         String   // "18:00"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barberProfile BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)

  @@map("barber_availability")
}

// ==========================================
// 6. PLANOS DE ASSINATURA
// ==========================================

model Plan {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String        @db.ObjectId
  name            String
  description     String?
  price           Float
  badge           String?       // Ex: "Recomendado", "Mais popular", "Premium"
  includedServiceIds String[] @db.ObjectId // IDs dos serviços incluídos neste plano
  commissionTiers Json          // [{"level":1,"percentage":20},{"level":2,"percentage":10}]
  status          PlanStatus    @default(ACTIVE)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("plans")
}

// ==========================================
// 7. SERVIÇOS
// ==========================================

model Service {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String      @db.ObjectId
  name            String
  description     String?
  price           Float
  duration        Int         // Duração em minutos
  category        String?     // Ex: "Corte", "Barba", "Hidratação"
  commissionTiers Json        // [{"level":1,"percentage":20}]
  status          ServiceStatus @default(ACTIVE)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("services")
}

// ==========================================
// 8. AGENDAMENTOS
// ==========================================

model Agendamento {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId  String   @db.ObjectId
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  barberId   String   @db.ObjectId // TenantMember id (role BARBER)
  barber     TenantMember @relation("BarberAppointments", fields: [barberId], references: [id])
  clientId   String   @db.ObjectId // TenantMember id (role CLIENT)
  client     TenantMember @relation("ClientAppointments", fields: [clientId], references: [id])
  date       DateTime
  startTime  String   // "08:00"
  endTime    String   // "08:30"
  status     String   @default("AGENDADO") // AGENDADO, CONFIRMADO, EM_ATENDIMENTO, CONCLUIDO, NOSHOW, CANCELADO
  notes      String?
  serviceIds String[] @db.ObjectId

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, date])
  @@index([barberId])
  @@index([clientId])
  @@map("agendamentos")
}

// ==========================================
// ENUNS
// ==========================================
enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}
enum TenantRole {
  OWNER
  BARBER
  CLIENT
}
enum CompanyStatus {
  ACTIVE
  BLOCKED
  INACTIVE
  CLAIMABLE
}

enum CouponStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}
